# Copy this file to `.env` in the project root (next to manage.py).
# `.env` is gitignored — never commit real passwords.

# Render Postgres External URL (from sopm-db → Connect → External)
DATABASE_URL=postgresql://USER:PASSWORD@dpg-xxxxx-a.region.postgres.render.com/sopm

# Optional local overrides
# DJANGO_DEBUG=true
# DJANGO_SECRET_KEY=change-me-for-local-only
